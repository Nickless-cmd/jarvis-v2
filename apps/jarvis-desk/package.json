{
  "name": "jarvis-desktop",
  "productName": "J.A.R.V.I.S.",
  "private": true,
  "version": "0.3.37",
  "description": "J.A.R.V.I.S. — Calm, robust desktop app. Built on /chat/stream/v2 Anthropic-style protocol.",
  "homepage": "https://github.com/Nickless-cmd/jarvis-v2",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k -n vite,electron -c blue,green \"vite\" \"wait-on http://localhost:5174 && npm run build:electron && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"require('fs').mkdirSync('dist-electron',{recursive:true});require('fs').writeFileSync('dist-electron/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "build": "npm run build:renderer && npm run build:electron",
    "package:linux": "npm run build && electron-builder --linux",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "dk.srvlab.jarvis",
    "productName": "J.A.R.V.I.S.",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "icon": "assets/icon.png",
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Office",
      "icon": "assets/icon.png",
      "maintainer": "Nickless <admin@srvlab.dk>",
      "executableName": "jarvis-desktop"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        },
        {
          "target": "zip",
          "arch": "universal"
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Nickless-cmd",
        "repo": "jarvis-v2"
      }
    ]
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "discord.js": "^14.26.4",
    "electron-updater": "^6.8.9",
    "katex": "^0.16.47",
    "lucide-react": "^0.460.0",
    "mermaid": "^11.15.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.29.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.1.9",
    "wait-on": "^7.2.0"
  }
}
