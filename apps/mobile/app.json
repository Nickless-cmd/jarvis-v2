{
  "expo": {
    "name": "Jarvis",
    "slug": "jarvis-mobile",
    "version": "0.1.14",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "dk.srvlab.jarvis.mobile",
      "versionCode": 15,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-camera"
    ],
    "icon": "./assets/icon.png"
  }
}